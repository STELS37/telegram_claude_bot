[Unit]
Description=Claude Telegram Bot Parallel
Wants=network-online.target
After=network-online.target omniroute.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/a0/usr/projects/telegram_claude_bot
EnvironmentFile=/etc/claude-telegram-bot-parallel.env
RuntimeDirectory=claude-telegram-bot-parallel
RuntimeDirectoryMode=0755
ExecStartPre=/usr/bin/test -x /usr/bin/claude
ExecStart=/usr/bin/node /a0/usr/projects/telegram_claude_bot/bot.js /a0/usr/projects/telegram_claude_bot/config-linux-parallel.json
Restart=always
RestartSec=5
KillMode=control-group
TimeoutStopSec=15
NoNewPrivileges=false

[Install]
WantedBy=multi-user.target
